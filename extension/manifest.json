{
  "manifest_version": 3,
  "name": "ElementSelector",
  "version": "1.2.52",
  "description": "页面元素选择器 - 让非程序员也能精确描述 UI 元素",
  "permissions": ["activeTab", "scripting", "storage"],
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "🎯 ElementSelector（点击启动/停止）"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "toggle-selector": {
      "suggested_key": {
        "default": "Alt+S"
      },
      "description": "开启/关闭元素选择器"
    }
  }
}
